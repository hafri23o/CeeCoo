# ==============================================================================
# NeonStream — Environment Variables Reference
# ==============================================================================
# This file documents all environment variables required by the project.
# DO NOT put real secrets in this file — it is safe to commit to version control.
#
# In Replit: add real values via the "Secrets" tab in the Tools panel.
# Locally: copy this file to .env and fill in your actual values.
# ==============================================================================


# ------------------------------------------------------------------------------
# Firebase — Authentication & Backend Services
# Source: https://console.firebase.google.com
#   → Select your project
#   → Project Settings → General → Your Apps → SDK setup and configuration
# ------------------------------------------------------------------------------

# Firebase Web API key
# Identifies your Firebase project to Google's services.
VITE_FIREBASE_API_KEY=AIzaSyC63LVrCNZ2mk8t3jbqvpbDDErdXasu0Nc

# Firebase Auth domain
# Used for OAuth sign-in redirect flows (e.g. Google Sign-In).
# Format: <your-project-id>.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=myfirst-4103c.firebaseapp.com

# Firebase project ID
# The unique identifier for your Firebase project.
VITE_FIREBASE_PROJECT_ID=myfirst-4103c

# Firebase Cloud Storage bucket
# Used if you store user-uploaded files via Firebase Storage.
# Format: <your-project-id>.appspot.com
VITE_FIREBASE_STORAGE_BUCKET=myfirst-4103c.firebasestorage.app

# Firebase Cloud Messaging sender ID
# Required for push notifications via Firebase Cloud Messaging (FCM).
VITE_FIREBASE_MESSAGING_SENDER_ID=630575055900

# Firebase App ID
# Unique identifier for this specific web app registered in your Firebase project.
# Format: 1:<sender-id>:web:<unique-hash>
VITE_FIREBASE_APP_ID=1:630575055900:web:85a0470b7b15dcf1174bd9
